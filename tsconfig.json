{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "tests/features",
    "types": ["node", "@playwright/test"],
    "paths": {
      "@auth/*": ["auth/*"],
      "@article/*": ["article/*"],
      "@config/*": ["../config/*"],
      "@shared/*": ["../shared/*"],
      "@setup/*": ["../setup/*"],
    },
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules"]
}